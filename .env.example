# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qr_pamyat
POSTGRES_USER=qr_app
POSTGRES_PASSWORD=qr_app

DATABASE_URL=postgresql+asyncpg://qr_app:qr_app@localhost:5432/qr_pamyat

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change_me_min_32_chars_random_string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,https://qr-pamyat.ru

# === Yandex Object Storage (локально — MinIO) ===
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=qr-pamyat-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central1
CDN_BASE_URL=https://cdn.qr-pamyat.ru

# === ЮKassa ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://127.0.0.1:5173/order/success
YOOKASSA_WEBHOOK_SECRET=

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Локальное хранение медиа (относительные пути в БД) ===
# Абсолютный путь на сервере или относительный к корню проекта (uploads/)
MEDIA_STORAGE_ROOT=uploads
MEDIA_STORAGE_BUCKET=local

# === Frontend (build-time) ===
VITE_API_BASE_URL=/api/v1
